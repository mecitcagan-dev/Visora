# Backend API (Render)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Public site origin for canonical / sitemap / Open Graph (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Search Console / Bing Webmaster meta verification (optional — leave empty until you have tokens)
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
